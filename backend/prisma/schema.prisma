// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Base {
  id      String @id
  name    String
  job     String
  profile String
}

model Projecs {
  id      String @id
  name    String
  picture String
  link    String
  desc    String
}